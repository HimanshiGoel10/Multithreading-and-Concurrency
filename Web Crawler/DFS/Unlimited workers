#include <iostream>
#include<thread>
#include<semaphore>
#include<mutex>
#include<condition_variable>
#include<chrono>

using namespace std;

class WebCrawler {
    private:
    
    unordered_map <string,bool> visited;
    mutex mtx;
    
    vector<string> parser (string url){
        if(url=="abc.com"){
            return {"bcd.com", "def.com", "ghi.com"};
        }
        if(url=="ghi.com"){
            return {"abc.com"};
        }
        return {};
    }
    
    public:
    
    WebCrawler(){
        // constructor
    }
    
    void executeDFS (string url){
        {
        unique_lock <mutex> lock(mtx);
        if(visited.find(url)!=visited.end()){
            return;
        }
        
        visited[url] = true;
        }
        
        cout<<"URL is - "<<url<< " "<< this_thread::get_id()<<endl; 
        
        vector<thread> v;
        
        for(auto &childUrl: parser(url)){
            v.push_back(thread(&WebCrawler:: executeDFS, this, childUrl));
        }
        
        for(int i=0; i<v.size(); i++){
            v[i].join();
        }
    }
    
    ~WebCrawler(){
        //destructor
    }
};

int main() {
    WebCrawler webcrawler;
    thread t1 = thread(&WebCrawler::executeDFS, &webcrawler, "abc.com");
    
    t1.join();
    return 0;
}
