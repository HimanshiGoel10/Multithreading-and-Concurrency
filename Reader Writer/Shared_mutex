#include <iostream>
#include <thread>
#include<semaphore>
#include<shared_mutex>
#include<mutex>

using namespace std;

class ReaderWriter {
    
    private:
    int data;
    shared_mutex mtx;
    
    
    public:
    
    ReaderWriter(int data){
        this->data = data; 
    }
    
    void reader (){
        shared_lock <shared_mutex> lock (mtx);
        cout<<data<<" ";
    }
    
    void writer(){
        unique_lock <shared_mutex> lock (mtx);
        data += 10;
    }
};

int main() {
    ReaderWriter readerWriter(0);
    thread t1 = thread(&ReaderWriter::reader, &readerWriter);
    thread t2 = thread(&ReaderWriter::reader, &readerWriter);
    thread t3 = thread(&ReaderWriter::writer, &readerWriter);
    thread t4 = thread(&ReaderWriter::reader, &readerWriter);
    
    t1.join();
    t2.join();
    t3.join();
    t4.join();
}
