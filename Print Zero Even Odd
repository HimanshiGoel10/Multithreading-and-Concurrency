class ZeroEvenOdd {
private:
    int n;
    mutex mtx;
    condition_variable cv;

    bool zeroTurn;
    bool oddTurn;
    bool evenTurn;

public:
    ZeroEvenOdd(int n) {
        this->n = n;
        zeroTurn = true;
        oddTurn = false;
        evenTurn = false;
    }

    // printNumber(x) outputs "x", where x is an integer.
    void zero(function<void(int)> printNumber) {
        for(int i=1; i<=n; i++){
            unique_lock <mutex> lock(mtx);
            while(!zeroTurn){
                cv.wait(lock);
            }
            printNumber(0);
            zeroTurn = false;
            if(i%2){
                oddTurn = true;
            }
            else evenTurn = true;
            cv.notify_all();
        }
    }

    void even(function<void(int)> printNumber) {
        for(int i=2; i<=n; i+=2){
            unique_lock <mutex> lock(mtx);
            while(!evenTurn){
                cv.wait(lock);
            }
            printNumber(i);
            zeroTurn = true;
            evenTurn = false;
            cv.notify_all();
        }
    }

    void odd(function<void(int)> printNumber) {
        for(int i=1; i<=n; i+=2){
            unique_lock <mutex> lock(mtx);
            while(!oddTurn){
                cv.wait(lock);
            }
            printNumber(i);
            zeroTurn = true;
            oddTurn = false;
            cv.notify_all();
        }
    }
};
