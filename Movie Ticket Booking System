#include <iostream>
#include <vector>
#include <mutex>
#include <thread>

using namespace std;

class MovieBookingSystem {
private:
    vector<bool> seats;
    mutex mtx;

public:
    MovieBookingSystem(int totalSeats)
    {
        seats.resize(totalSeats, false);
    }

    bool bookSeat(int seatId)
    {
        lock_guard<mutex> lock(mtx);

        if(seats[seatId])
            return false;

        seats[seatId] = true;
        return true;
    }

    bool cancelSeat(int seatId)
    {
        lock_guard<mutex> lock(mtx);

        if(!seats[seatId])
            return false;

        seats[seatId] = false;
        return true;
    }

    bool isAvailable(int seatId)
    {
        lock_guard<mutex> lock(mtx);
        return !seats[seatId];
    }
};

void user(MovieBookingSystem& system,
          int userId,
          int seatId)
{
    if(system.bookSeat(seatId))
    {
        cout << "User "
             << userId
             << " booked seat "
             << seatId
             << endl;
    }
    else
    {
        cout << "User "
             << userId
             << " failed\n";
    }
}

int main()
{
    MovieBookingSystem system(100);

    thread t1(user, ref(system), 1, 10);
    thread t2(user, ref(system), 2, 10);
    thread t3(user, ref(system), 3, 10);

    t1.join();
    t2.join();
    t3.join();
}
