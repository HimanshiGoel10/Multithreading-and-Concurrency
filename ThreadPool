}
int main() {
    ThreadPool threadpool(3);
    thread t1 = thread(&ThreadPool::submit, &threadpool, task);
    thread t2 = thread(&ThreadPool::submit, &threadpool, task);
    thread t3 = thread(&ThreadPool::submit, &threadpool, task);
    thread t4 = thread(&ThreadPool::submit, &threadpool, task);
    thread t5 = thread(&ThreadPool::submit, &threadpool, task);
    thread t6 = thread(&ThreadPool::submit, &threadpool, task);
    t1.join(); t2.join();
    t3.join(); t4.join();
    t5.join(); t6.join();
    return 0;
}
