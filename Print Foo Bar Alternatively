class FooBar {
private:
    int n;
    bool fooTurn;
    mutex mtx;
    condition_variable cv;

public:
    FooBar(int n) {
        this->n = n;
        fooTurn = true;
    }

    void foo(function<void()> printFoo) {
        
        for (int i = 0; i < n; i++) {
            
        	// printFoo() outputs "foo". Do not change or remove this line.
            unique_lock <mutex> lock(mtx);
            while(!fooTurn){
                cv.wait(lock);
            }
        	printFoo();
            fooTurn = false;
            cv.notify_all();
        }
    }

    void bar(function<void()> printBar) {
        
        for (int i = 0; i < n; i++) {
            
        	// printBar() outputs "bar". Do not change or remove this line.
            unique_lock <mutex> lock(mtx);
            while(fooTurn){
                cv.wait(lock);
            }
        	printBar();
            fooTurn = true;
            cv.notify_all();
        	
        }
    }
};
