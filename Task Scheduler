#include <iostream>
#include <queue>
#include <thread>
#include <vector>
#include <mutex>
#include <condition_variable>
#include <functional>

using namespace std;

class TaskScheduler {
private:
    queue<function<void()>> tasks;

    vector<thread> workers;

    mutex mtx;
    condition_variable cv;

    condition_variable completeCv;

    bool stop = false;
    int activeTasks = 0;

    void worker() {

        while (true) {

            function<void()> task;

            {
                unique_lock<mutex> lock(mtx);

                cv.wait(lock, [&]() {
                    return stop || !tasks.empty();
                });

                if (stop && tasks.empty())
                    return;

                task = move(tasks.front());
                tasks.pop();

                activeTasks++;
            }

            task();

            {
                lock_guard<mutex> lock(mtx);

                activeTasks--;

                if (tasks.empty() &&
                    activeTasks == 0)
                {
                    completeCv.notify_all();
                }
            }
        }
    }

public:

    TaskScheduler(int numThreads) {

        for (int i = 0; i < numThreads; i++) {
            workers.emplace_back(
                &TaskScheduler::worker,
                this
            );
        }
    }

    void schedule(function<void()> task) {

        {
            lock_guard<mutex> lock(mtx);
            tasks.push(move(task));
        }

        cv.notify_one();
    }

    void waitUntilComplete() {

        unique_lock<mutex> lock(mtx);

        completeCv.wait(lock, [&]() {
            return tasks.empty() &&
                   activeTasks == 0;
        });
    }

    ~TaskScheduler() {

        {
            lock_guard<mutex> lock(mtx);
            stop = true;
        }

        cv.notify_all();

        for (auto& t : workers) {
            t.join();
        }
    }
};

int main() {

    TaskScheduler scheduler(3);

    for (int i = 1; i <= 10; i++) {

        scheduler.schedule([i]() {

            cout << "Task "
                 << i
                 << " running\n";

            this_thread::sleep_for(
                chrono::seconds(1));
        });
    }

    scheduler.waitUntilComplete();

    cout << "All tasks finished\n";
}
